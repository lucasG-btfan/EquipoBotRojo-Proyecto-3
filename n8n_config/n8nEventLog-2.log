},\"base_url\":\"https://generativelanguage.googleapis.com\",\"model\":\"gemini-2.5-flash\"},\"response\":{\"response\":{\"generations\":[[{\"text\":\"Lo siento, Rafael, no tengo información específica de salones en Maipú, Mendoza en este momento.\\n\\n¿Te gustaría que te muestre los salones destacados que tenemos disponibles o tienes alguna otra consulta?\",\"generationInfo\":{\"finishReason\":\"STOP\",\"index\":0}}]]},\"tokenUsage\":{\"completionTokens\":43,\"promptTokens\":447,\"totalTokens\":490}}}"}}
